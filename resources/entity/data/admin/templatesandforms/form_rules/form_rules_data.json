{
	"change_fafr_actions_mandate": {
		"data": {
			"change_fafr": {
				"applies_to_all_templates": false,
				"execute_on": "both",
				"applies_to": "all_users",
				"event": "on_field_change",
				"is_enabled": true,
				"on_field_change": "category",
				"name": "fafr_$(unique_string)",
				"templates": [
					{
						"id": "$(custom_change_TempId)"
					}
				],
				"criteria": [
					{
						"field": "title",
						"condition": "is",
						"values": [
							"$(custom_changeTitle)"
						],
						"logical_operator": "AND"
					},
					{
						"field": "category",
						"condition": "is",
						"values": [
							{
								"id": "$(custom_categoriesId)",
								"name": "$(custom_categoryName)"
							}
						],
						"logical_operator": "AND"
					}
				],
				"actions": [
					{
						"mandate_fields": [
							"downtimes_data"
						]
					}
				]
			}
		}
	},
